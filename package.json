{
    "name": "pretty-checkbox-react",
    "version": "3.2.0",
    "description": "A set of React components build around Pretty Checkbox",
    "keywords": [
        "Pretty",
        "Radio",
        "Switch",
        "Pretty Checkbox",
        "Pretty Checkbox React",
        "pretty-checkbox",
        "pretty-checkbox-react",
        "Components",
        "input controls",
        "React",
        "React Hooks",
        "CSS",
        "Checkbox",
        "Preact"
    ],
    "module": "dist-module/pcr.mjs",
    "main": "dist-main/pcr.js",
    "types": "dist-types/index.d.ts",
    "files": [
        "dist-*",
        "src"
    ],
    "scripts": {
        "lint": "eslint src --ext=js,ts,tsx",
        "prepare": "husky install",
        "test": "jest",
        "clean": "rimraf dist-*",
        "build": "npm-run-all -p clean -s build:*",
        "build:iife": "esbuild src/index.ts --bundle --minify --external:react --sourcemap --format=iife --global-name=PrettyCheckboxReact --outfile=dist-browser/pcr.iife.min.js",
        "build:esm": "esbuild src/index.ts --bundle --external:react --sourcemap --format=esm --outfile=dist-module/pcr.mjs",
        "build:cjs": "esbuild src/index.ts --bundle --external:react --sourcemap --format=cjs --outfile=dist-main/pcr.js",
        "build:types": "tsc --emitDeclarationOnly --declaration --declarationMap --declarationDir dist-types",
        "ts": "tsc --noEmit",
        "start": "cd docs && yarn && yarn start"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/atomicpages/pretty-checkbox-react.git"
    },
    "author": "Dennis Thompson",
    "maintainers": [
        "Dennis Thompson"
    ],
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/atomicpages/pretty-checkbox-react/issues"
    },
    "homepage": "https://github.com/atomicpages/pretty-checkbox-react#readme",
    "peerDependencies": {
        "pretty-checkbox": "^3.0.0",
        "react": ">=16.9.0",
        "react-dom": ">=16.9.0"
    },
    "devDependencies": {
        "@djthoms/eslint-config": "^4.0.0",
        "@djthoms/prettier-config": "^3.0.0",
        "@testing-library/jest-dom": "^5.11.4",
        "@testing-library/react": "^12.0.0",
        "@testing-library/react-hooks": "^7.0.0",
        "@types/jest": "^26.0.23",
        "@types/node": "^14.6.0",
        "@types/react": "^17.0.0",
        "esbuild": "^0.12.9",
        "eslint": "^7.7.0",
        "husky": "^6.0.0",
        "jest": "^27.0.0",
        "lint-staged": "^11.0.0",
        "npm-run-all": "^4.1.5",
        "prettier": "^2.1.1",
        "pretty-checkbox": "^3.0.3",
        "react": "^17.0.0",
        "react-dom": "^17.0.0",
        "react-test-renderer": "^17.0.0",
        "rimraf": "^3.0.2",
        "ts-jest": "^27.0.0",
        "ts-node": "^10.0.0",
        "typescript": "^4.0.2"
    },
    "dependencies": {
        "clsx": "^1.1.1",
        "nanoid": "^3.0.0",
        "react-merge-refs": "^1.1.0"
    },
    "prettier": "@djthoms/prettier-config",
    "lint-staged": {
        "*.{ts,tsx,js}": [
            "prettier --write",
            "eslint --fix"
        ],
        "*.{md,yml,yaml,json}": "prettier --write"
    }
}
