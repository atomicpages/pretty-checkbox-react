{
  "name": "pretty-checkbox-react",
  "version": "3.2.0",
  "description": "A set of React components build around Pretty Checkbox",
  "keywords": [
    "Pretty",
    "Radio",
    "Switch",
    "Pretty Checkbox",
    "Pretty Checkbox React",
    "pretty-checkbox",
    "pretty-checkbox-react",
    "Components",
    "input controls",
    "React",
    "React Hooks",
    "CSS",
    "Checkbox",
    "Preact"
  ],
  "homepage": "https://github.com/atomicpages/pretty-checkbox-react#readme",
  "bugs": {
    "url": "https://github.com/atomicpages/pretty-checkbox-react/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atomicpages/pretty-checkbox-react.git"
  },
  "license": "MIT",
  "author": "Dennis Thompson",
  "maintainers": [
    "Dennis Thompson"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.mts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./checkbox": {
      "import": {
        "types": "./dist/esm/components/checkbox/Checkbox.d.mts",
        "default": "./dist/esm/components/checkbox/Checkbox.mjs"
      },
      "require": {
        "types": "./dist/cjs/components/checkbox/Checkbox.d.ts",
        "default": "./dist/cjs/components/checkbox/Checkbox.js"
      }
    },
    "./radio": {
      "import": {
        "types": "./dist/esm/components/radio/Radio.d.mts",
        "default": "./dist/esm/components/radio/Radio.mjs"
      },
      "require": {
        "types": "./dist/cjs/components/radio/Radio.d.ts",
        "default": "./dist/cjs/components/radio/Radio.js"
      }
    },
    "./switch": {
      "import": {
        "types": "./dist/esm/components/switch/Switch.d.mts",
        "default": "./dist/esm/components/switch/Switch.mjs"
      },
      "require": {
        "types": "./dist/cjs/components/switch/Switch.d.ts",
        "default": "./dist/cjs/components/switch/Switch.js"
      }
    }
  },
  "scripts": {
    "lint": "eslint src --ext=js,ts,tsx",
    "prepare": "husky",
    "test": "jest -w 4",
    "test:fast": "jest -w 4 --collectCoverage=false",
    "build": "tsup",
    "ts-check": "tsc --noEmit",
    "start": "cd docs && pnpm install && pnpm start",
    "version": "npm run build",
    "prepush": "npm-run-all -p lint ts-check -s test:fast"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "nanoid": "^3.3.7",
    "react-merge-refs": "^1.1.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.15.3",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@djthoms/eslint-config": "^6.4.2",
    "@djthoms/prettier-config": "^4.4.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "glob": "^10.4.3",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.7",
    "npm-run-all": "^4.1.5",
    "pretty-checkbox": "^3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-test-renderer": "^18.3.1",
    "semantic-release": "^24.0.0",
    "ts-jest": "^29.1.5",
    "tsup": "^8.1.0",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "pretty-checkbox": "^3.0.0",
    "react": ">=16.9.0",
    "react-dom": ">=16.9.0"
  }
}
